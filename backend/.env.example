# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-32
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── AWS (required for production media storage on S3) ────────────────────────
# These are set automatically by EC2 user_data via Terraform
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1
AWS_STORAGE_BUCKET_NAME=   # e.g. portfolio-media-a1b2c3d4

# ── CloudFront (optional — adds CF domain to CORS_ALLOWED_ORIGINS) ────────────
CLOUDFRONT_DOMAIN=         # e.g. d1234567890.cloudfront.net

# ── Database (PostgreSQL for production / SQLite fallback when unset) ───────
# DB_ENGINE=postgres
# DB_NAME=portfolio
# DB_USER=portfolio
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432
# DB_SSLMODE=prefer
