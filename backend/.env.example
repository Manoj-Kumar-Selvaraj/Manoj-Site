# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-32
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── AWS (required for production media storage on S3) ────────────────────────
# These are set automatically by EC2 user_data via Terraform
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1
AWS_STORAGE_BUCKET_NAME=   # e.g. portfolio-media-a1b2c3d4

# ── CloudFront (optional — adds CF domain to CORS_ALLOWED_ORIGINS) ────────────
CLOUDFRONT_DOMAIN=         # e.g. d1234567890.cloudfront.net
STATIC_CDN_DOMAIN=         # optional override for Django static URLs; defaults to CLOUDFRONT_DOMAIN
MEDIA_CDN_DOMAIN=          # optional dedicated CDN domain for media URLs
MEDIA_URL_PREFIX=          # optional media path prefix on MEDIA_CDN_DOMAIN (e.g. media)
USE_PRIMARY_CDN_FOR_MEDIA=False  # set True only if CLOUDFRONT_DOMAIN can serve media objects
AWS_S3_CACHE_CONTROL=public, max-age=31536000, immutable

# ── Email / Contact Notifications ────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=
CONTACT_NOTIFICATION_EMAIL=
CONTACT_SUBMIT_RATE=3/hour
CONTACT_MIN_FORM_FILL_MS=2500

# ── Database (PostgreSQL for production / SQLite fallback when unset) ───────
# DB_ENGINE=postgres
# DB_NAME=portfolio
# DB_USER=portfolio
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432
# DB_SSLMODE=prefer
